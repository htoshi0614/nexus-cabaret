# ============================================================
# POSStart 環境設定ファイル
# このファイルを .env という名前でコピーして使ってください
# cp .env.example .env
# ============================================================

# ── Stripe 設定（必須）─────────────────────────────────────
# Stripeダッシュボード → Developers → API keys から取得
STRIPE_SECRET_KEY=あなたのシークレットキーをここに貼る

# Stripeダッシュボード → Developers → Webhooks から取得
STRIPE_WEBHOOK_SECRET=あなたのWebhookシークレットをここに貼る

# 月額プランの Price ID（変更した場合のみ更新）
STRIPE_PRICE_ID_MONTHLY=price_1TXmQl2MxG8VbLpzn12I9hLK

# ── サーバー設定（任意）──────────────────────────────────────
# ngrokやVPSで使う場合はサーバーのURLを設定
# BASE_URL=https://concentric-unofficiously-arabella.ngrok-free.dev
